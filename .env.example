# ---- Server ----
PORT=10002
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ---- JWT (OBLIGATOIRE en production) ----
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-please-use-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Paths ----
DATA_DIR=./config
KEYS_DIR=./keys
LOGS_DIR=./logs

# ---- SSH reconnection backoff ----
RECONNECT_BASE_MS=1000
RECONNECT_MAX_MS=30000

# ---- Stats ----
STATS_WINDOW_SEC=300
STATS_24H_FILE=true

# ---- Bandwidth limiter ----
BANDWIDTH_BUCKET_MS=100
